# Люба (@asluba_bot) — бот-собеседник, активный в группах и чатах

# ── Telegram (put real values in .env or GitHub Secrets, NOT here) ──
BOT_TOKEN=your_bot_token_here
BOT_USERNAME=@asluba_bot
BOT_ID=8614302697
OWNER_ID=265070804

# ── Local model (RuadaptQwen3-4B-Instruct GGUF, CPU) — PRIMARY like Asya ──
ENABLE_LOCAL_MODEL=true
MODEL_PATH=models/RuadaptQwen3-4B-Instruct-Q4_K_M.gguf
MODEL_N_CTX=8192
MODEL_N_THREADS=3
MODEL_MAX_TOKENS=1024
MODEL_AUTO_DOWNLOAD=true
MODEL_DOWNLOAD_URL=https://huggingface.co/RefalMachine/RuadaptQwen3-4B-Instruct-GGUF/resolve/main/Q4_K_M.gguf
HF_TOKEN=your_huggingface_token_here

# ── Pollinations AI (FREE, no auth required) — always-available cloud fallback ──
POLLINATIONS_FREE_TEXT_URL=https://text.pollinations.ai
POLLINATIONS_FREE_IMAGE_URL=https://image.pollinations.ai
# Optional authenticated keys (better rate limits) — leave empty to use free API
POLLINATIONS_API_KEY=
POLLINATIONS_API_KEY_2=

# ── OPTIONAL free cloud providers (auto-enabled when key present) ──
# GitHub Models — FREE AI catalog by GitHub (gpt-4o, gpt-4o-mini, Llama-3.1-405B/8B)
# Create a classic PAT with 'models' scope at https://github.com/settings/tokens
GH_MODELS_TOKEN=
# Groq (free tier, very fast, Llama 3.3 70B etc.)
GROQ_API_KEY=
# Google Gemini (free tier)
GEMINI_API_KEY=
# OpenRouter (free models available)
OPENROUTER_API_KEY=
# Cloudflare Workers AI (10K req/day free per account)
CF_ACCOUNT_ID_1=
CF_API_TOKEN_1=
CF_ACCOUNT_ID_2=
CF_API_TOKEN_2=

# ── GitHub PAT (self-dispatch for 24/7 in Actions) ──
GH_PAT_TOKEN=your_github_pat_here
GH_REPO=sochiautoparts/luba

# ── Database ──
DB_PATH=luba.db

# ── Partner / affiliate programs (same source as Asya) ──
PARTNERS_URL=https://sochiautoparts.ru/partners.json
ADMITAD_ADS_FILE=data/partners.json
PARTNER_REFRESH_HOURS=6

# ── Group activity tuning ──
# Probability [0..1] that Lyuba proactively comments on a group message
# that is NOT directed at her (to be "very active" but not spammy)
GROUP_PROACTIVE_PROB=0.35
# Min seconds between Lyuba's messages in the same group (anti-flood)
GROUP_MIN_INTERVAL=12
# Max messages Lyuba remembers per group for context
GROUP_MEMORY_SIZE=30

# ── Web verification ──
SEARCH_TIMEOUT_SECONDS=8
WEB_VERIFY_PROB=0.5

# ── Log level ──
LOG_LEVEL=INFO
