# Люба (@asluba_bot) — Environment variables
# In GitHub Actions these are set as repository Secrets.

# ── Telegram (REQUIRED) ──
BOT_TOKEN=
BOT_USERNAME=@asluba_bot
BOT_ID=8614302697
OWNER_ID=265070804

# ── GitHub PAT for 24/7 self-dispatch (REQUIRED for Actions) ──
GH_PAT_TOKEN=
GH_REPO=sochiautoparts/luba

# ── OpenClaw gateway ──
OPENCLAW_PORT=18789

# ── AI Providers (OPTIONAL — bot works on Pollinations free without any key) ──
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
HF_TOKEN=
CEREBRAS_API_KEY=
MISTRAL_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
POLLINATIONS_API_KEY=

# ── Behaviour tuning ──
GROUP_PROACTIVE_PROB=0.75
GROUP_MAX_PER_MINUTE=15
GROUP_MEMORY_SIZE=30
CHANNEL_REACTION_PROB=0.65
REACTION_PROB=0.45
WEB_VERIFY_PROB=1.0
SEARCH_TIMEOUT_SECONDS=8
LOG_LEVEL=INFO

# ── Partners / affiliate ──
PARTNERS_URL=https://sochiautoparts.ru/partners.json
PARTNER_REFRESH_HOURS=6
